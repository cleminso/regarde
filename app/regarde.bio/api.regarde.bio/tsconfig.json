{
  "$schema": "https://www.schemastore.org/tsconfig",
  "references": [{ "path": "./tsconfig.node.json" }],
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@regarde-dev/jazz-schemas": ["../../jazz-schemas/src/index.ts"],
      "@regarde-dev/jazz-schemas/regarde.bio": [
        "../../jazz-schemas/src/regarde.bio/index.ts"
      ]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "vite.config.ts"]
}
