{
  "name": "@regarde-dev/core",
  "version": "1.0.0",
  "description": "Regarde SDK for React and Preact with registration token logic",
  "keywords": [
    "jazz-tools",
    "preact",
    "react",
    "regarde",
    "sdk"
  ],
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/cleminso/regarde.git",
    "directory": "packages/sdk"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./preact": {
      "types": "./dist/preact.d.ts",
      "import": "./dist/preact.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && NODE_ENV=production vite build",
    "build:test": "rm -rf dist && NODE_ENV=test vite build",
    "dev": "DOTENV_CONFIG_PATH=.env.local vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "run:test": "DOTENV_CONFIG_PATH=.env.test NODE_ENV=test node dist/index.mjs",
    "start": "DOTENV_CONFIG_PATH=.env.production NODE_ENV=production node dist/index.mjs"
  },
  "dependencies": {
    "@scure/bip39": "catalog:",
    "jazz-tools": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "preact": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@polar-sh/sdk": "^0.46.3",
    "preact": "^10.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "stripe": "^20.4.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "preact": {
      "optional": true
    },
    "stripe": {
      "optional": true
    },
    "@polar-sh/sdk": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.32.1"
}
