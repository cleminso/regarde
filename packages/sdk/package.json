{
  "name": "@regarde-dev/sdk",
  "version": "1.0.0",
  "description": "Regarde SDK for React and Preact with registration token logic",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/cleminso/regarde.git",
    "directory": "packages/sdk"
  },
  "scripts": {
    "build": "rm -rf dist && vite build",
    "dev": "vite build --watch",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "regarde",
    "sdk",
    "react",
    "preact",
    "jazz-tools"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.16.1",
  "dependencies": {
    "jazz-tools": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "preact": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "preact": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/node": "catalog:",
    "@scure/bip39": "catalog:",
    "react": "catalog:",
    "preact": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth.js",
      "require": "./dist/auth.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./preact": {
      "types": "./dist/preact/index.d.ts",
      "import": "./dist/preact.js",
      "require": "./dist/preact.cjs"
    },
    "./verify": {
      "types": "./dist/verify/index.d.ts",
      "import": "./dist/verify.js",
      "require": "./dist/verify.cjs"
    },
    "./regarde-users": {
      "types": "./dist/regarde-users/index.d.ts",
      "import": "./dist/regarde-users.js",
      "require": "./dist/regarde-users.cjs"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "import": "./dist/registry.js",
      "require": "./dist/registry.cjs"
    },
    "./payments": {
      "types": "./dist/payments/index.d.ts",
      "import": "./dist/payments.js",
      "require": "./dist/payments.cjs"
    },
    "./init": {
      "types": "./dist/init/index.d.ts",
      "import": "./dist/init.js",
      "require": "./dist/init.cjs"
    },
    "./app": {
      "types": "./dist/app/index.d.ts",
      "import": "./dist/app.js",
      "require": "./dist/app.cjs"
    }
  },
  "files": [
    "dist"
  ]
}
