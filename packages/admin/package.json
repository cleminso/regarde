{
  "name": "@onboarding.jazz/admin",
  "version": "0.1.0",
  "description": "CLI tool for profile nickname registry admin operations",
  "main": "dist/cli.js",
  "type": "module",
  "bin": {
    "profile-admin": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cleminso/onboarding.jazz.git",
    "directory": "packages/admin"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:schema": "pnpm --filter @onboarding.jazz/shared-schemas build",
    "build": "pnpm clean && pnpm run build:schema && tsc",
    "dev": "pnpm build:schema && bun --watch src/cli.ts",
    "cli": "pnpm build:schema && bun src/cli.ts"
  },
  "keywords": [
    "jazz",
    "admin",
    "cli",
    "nickname-registry"
  ],
  "dependencies": {
    "@alcyone-labs/arg-parser": "^2.6.0",
    "@onboarding.jazz/shared-schemas": "workspace:*",
    "dotenv": "^16.4.7",
    "jazz-tools": "^0.17.1",
    "ulidx": "^2.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "typescript": "^5.9.2"
  }
}
