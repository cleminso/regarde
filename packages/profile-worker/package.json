{
  "name": "@onboarding.jazz/profile-worker",
  "version": "0.1.0",
  "description": "Jazz.tool worker for nickname registration.",
  "main": "dist/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/cleminso/onboarding.jazz.git",
    "directory": "packages/profile-worker"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:schema": "pnpm --filter @onboarding.jazz/shared-schemas build",
    "build": "pnpm clean && pnpm run build:schema && tsc",
    "start": "pnpm build && node dist/index.js",
    "debug": "pnpm build && node --inspect dist/index.js",
    "start:bun": "pnpm build:schema && bun src/index.ts",
    "dev": "pnpm build:schema && bun --watch src/index.ts"
  },
  "keywords": [
    "jazz",
    "worker"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "^1.15.0",
    "@hono/swagger-ui": "^0.4.1",
    "@hono/zod-openapi": "^0.16.4",
    "@onboarding.jazz/shared-schemas": "workspace:*",
    "dotenv": "^16.6.1",
    "hono": "^4.8.3",
    "jazz-tools": "^0.15.7",
    "zod": "^3.25.71"
  },
  "devDependencies": {
    "@types/node": "^20.19.4",
    "nodemon": "^3.1.10",
    "typescript": "^5.8.3"
  }
}
