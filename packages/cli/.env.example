# Regarde CLI Environment Configuration
# Copy this file to .env.local, .env.test, or .env.production

# Worker account ID for the Regarde registry worker
# This worker manages the nickname registry and app metadata
REGARDE_REGISTRY_GROUP=your-worker-id-here

# Jazz sync server URL
# - Development/Testing: ws://localhost:4200
# - Production: wss://cloud.jazz.tools
JAZZ_SYNC_SERVER_URL=ws://localhost:4200

# Jazz API key (only needed for Jazz Cloud)
# Not required for local sync server
JAZZ_API_KEY=your-api-key-optional

# Testing credentials (for .env.test only)
# Used to test CLI commands with specific Jazz accounts
 TEST_JAZZ_ACCOUNT_ID=co_testAccount123
TEST_JAZZ_ACCOUNT_SECRET=test-secret-here
TEST_PASSPHRASE="test words one two three four five six seven eight nine ten eleven twelve"
