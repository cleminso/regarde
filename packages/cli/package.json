{
  "name": "@regarde-dev/cli",
  "version": "1.0.0",
  "description": "CLI for Regarde User",
  "main": "dist/index.js",
  "bin": {
    "regarde": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --dts",
    "dev": "tsup src/index.ts --format esm --watch --onSuccess \"node dist/index.js\"",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@alcyone-labs/arg-parser": "^2.8.2",
    "@noble/hashes": "^2.0.1",
    "@regarde-dev/sdk": "workspace:*",
    "@scure/base": "^2.0.0",
    "chalk": "^5.6.2",
    "dotenv": "^16.4.5",
    "inquirer": "^13.1.0",
    "jazz-tools": "latest",
    "node-fetch": "^3.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}