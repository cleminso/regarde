{
  "name": "@regarde-dev/cli",
  "version": "1.0.0",
  "description": "CLI for Regarde User",
  "main": "dist/index.mjs",
  "bin": {
    "regarde": "./dist/index.mjs"
  },
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && NODE_ENV=production vite build",
    "build:test": "rm -rf dist && NODE_ENV=test vite build",
    "dev": "DOTENV_CONFIG_PATH=.env.local vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup:local": "DOTENV_CONFIG_PATH=.env.test node scripts/setupLocalWorker.js",
    "setup:test-member": "DOTENV_CONFIG_PATH=.env.test node scripts/addTestMember.js",
    "setup": "pnpm setup:local && pnpm setup:test-member",
    "start": "DOTENV_CONFIG_PATH=.env.production NODE_ENV=production node dist/index.mjs",
    "start:test": "DOTENV_CONFIG_PATH=.env.test NODE_ENV=test node dist/index.mjs"
  },
  "dependencies": {
    "@alcyone-labs/arg-parser": "^2.13.4",
    "@noble/hashes": "^2.0.1",
    "@regarde-dev/core": "workspace:*",
    "@scure/base": "^2.0.0",
    "chalk": "^5.6.2",
    "cojson-transport-ws": "catalog:",
    "dotenv": "catalog:",
    "inquirer": "^13.2.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "jazz-tools": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "zod": "catalog:"
  }
}
