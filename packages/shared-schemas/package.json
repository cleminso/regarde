{
  "name": "@onboarding.jazz/shared-schemas",
  "repository": {
    "type": "git",
    "url": "https://github.com/cleminso/onboarding.jazz.git",
    "directory": "packages/shared-schemas"
  },
  "version": "0.1.0",
  "description": "Shared Jazz schemas for onboarding application",
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "scripts": {
    "build:tsc": "pnpm clean && tsc",
    "build:vite": "pnpm clean && vite build",
    "build": "pnpm build:tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "jazz-tools": "^0.15.7",
    "ulidx": "^2.4.1"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./profile": "./dist/profile.js",
    "./registry": "./dist/registry.js",
    "./nickname": "./dist/nickname.js"
  },
  "files": [
    "dist"
  ]
