{
  "name": "@regarde/shared-schemas",
  "repository": {
    "type": "git",
    "url": "https://github.com/cleminso/regarde.git",
    "directory": "packages/shared-schemas"
  },
  "version": "0.1.0",
  "description": "Shared Jazz schemas for regarde application",
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "scripts": {
    "build:tsc": "pnpm clean && tsc",
    "build:vite": "pnpm clean && vite build",
    "build": "pnpm build:tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "dependencies": {
    "jazz-tools": "catalog:",
    "ulidx": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./profile": {
      "types": "./dist/profile.d.ts",
      "import": "./dist/profile.js",
      "default": "./dist/profile.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js",
      "default": "./dist/registry.js"
    },
    "./nickname": {
      "types": "./dist/nickname.d.ts",
      "import": "./dist/nickname.js",
      "default": "./dist/nickname.js"
    }
  },
  "files": [
    "dist"
  ]
}
