{
  "name": "@regarde-dev/api.regarde.dev",
  "version": "1.0.0",
  "description": "api.regarde.dev API server",
  "main": "dist/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/cleminso/regarde.git",
    "directory": "packages/api.regarde.dev"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:schema": "pnpm --filter jazz-schemas build",
    "build": "pnpm clean && pnpm run build:schema && tsc",
    "start": "pnpm build && node dist/index.js",
    "debug": "pnpm build && node --inspect dist/index.js",
    "start:bun": "pnpm build:schema && bun src/index.ts",
    "dev": "pnpm build:schema && bun --watch src/index.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "keywords": [
    "jazz",
    "api",
    "nickname-registry",
    "authentication",
    "regarde"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "@hono/swagger-ui": "^0.4.1",
    "@hono/zod-openapi": "^1.1.4",
    "@regarde-dev/jazz-schemas": "workspace:*",
    "dotenv": "^16.6.1",
    "hono": "^4.9.4",
    "jazz-tools": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "nodemon": "^3.1.10",
    "typescript": "catalog:"
  }
}
