{
  "name": "@regarde-dev/api.regarde.dev",
  "version": "1.0.0",
  "description": "api.regarde.dev API server",
  "main": "dist/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/cleminso/regarde.git",
    "directory": "packages/api.regarde.dev"
  },
  "scripts": {
    "build": "rm -rf dist && vite build",
    "start": "node dist/index.js",
    "start:test": "DOTENV_CONFIG_PATH=.env.test node dist/index.js",
    "debug": "pnpm build && node --inspect dist/index.js",
    "start:bun": "bun src/index.ts",
    "start:test:bun": "DOTENV_CONFIG_PATH=.env.test bun src/index.ts",
    "dev": "vite build --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "keywords": [
    "jazz",
    "api",
    "nickname-registry",
    "authentication",
    "regarde"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@hono/swagger-ui": "catalog:",
    "@hono/zod-openapi": "catalog:",
    "@regarde-dev/core": "workspace:*",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "jazz-tools": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "nodemon": "^3.1.10",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:"
  }
}
