{
  "name": "@regarde/ui",
  "description": "Regarde UI Components — This is a private library for the Regarde project. You probably shouldn't use it directly in your own projects.",
  "author": "Regarde",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/components/atoms/*.d.ts",
      "import": "./dist/components/atoms/*.mjs",
      "require": "./dist/components/atoms/*.js"
    },
    "./data-table": {
      "types": "./dist/components/atoms/data-table/index.d.ts",
      "import": "./dist/components/atoms/data-table/index.mjs",
      "require": "./dist/components/atoms/data-table/index.js"
    },
    "./shadcn/*": {
      "types": "./dist/components/shadcn-ui/*.d.ts",
      "import": "./dist/components/shadcn-ui/*.mjs",
      "require": "./dist/components/shadcn-ui/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.mjs",
      "require": "./dist/lib/*.js"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "rm -rf dist && tsup",
    "lint": "oxlint .",
    "format": "oxfmt \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-table": "^8.21.0",
    "@tanstack/react-virtual": "^3.13.0",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "^1.1.1",
    "little-timestamp": "catalog:",
    "lucide-react": "catalog:",
    "shadcn": "^4.0.8",
    "next-themes": "0.4.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tsup": "^8.5.1",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
