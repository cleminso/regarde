{
  "scripts": {
    "dev": "pnpm -r dev",
    "build:core": "pnpm --filter \"@regarde-dev/core\" build",
    "build:packages": "pnpm --filter \"./packages/*\" --filter \"!@regarde-dev/core\" --filter \"@regarde-dev/jazz-schemas\" build",
    "build:apps": "pnpm --filter \"./apps/regarde.bio/*\" --filter \"!@regarde-dev/jazz-schemas\" build",
    "build": "pnpm build:core && pnpm build:packages && pnpm build:apps",
    "test": "pnpm -r test",
    "test:run": "pnpm --filter \"*.test.ts\" test:run",
    "cli": "node packages/cli/dist/index.mjs",
    "format-and-lint": "oxfmt . --check && oxlint --type-aware .",
    "format-and-lint:fix": "oxfmt . --write && oxlint --type-aware . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint:ci": "oxlint --type-aware . --deny-warnings",
    "lint:admin": "oxlint --type-aware packages/admin",
    "lint:sdk": "oxlint --type-aware packages/sdk",
    "lint:sdk:fix": "oxlint --type-aware packages/sdk --fix",
    "lint:dashboard": "oxlint --type-aware apps/dashboard.regarde.dev",
    "format:sdk": "oxfmt packages/sdk --write",
    "format:api": "oxfmt packages/api.regarde.dev --write",
    "format-and-lint:sdk": "oxfmt packages/sdk --check && oxlint --type-aware packages/sdk",
    "format-and-lint:sdk:fix": "oxfmt packages/sdk --write && oxlint --type-aware packages/sdk --fix",
    "format-and-lint:api": "oxfmt packages/api.regarde.dev --check && oxlint --type-aware packages/api.regarde.dev"
  },
  "dependencies": {
    "@scure/bip39": "catalog:",
    "beautiful-mermaid": "^1.1.3",
    "jazz-tools": "catalog:"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/ui": "catalog:",
    "cojson-core-rn": "catalog:",
    "esbuild": "^0.27.4",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "little-timestamp": "catalog:",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "rolldown": "1.0.0-beta.57",
    "vitest": "catalog:"
  }
}
