{
  "scripts": {
    "dev": "pnpm -r dev",
    "build:core": "pnpm --filter \"@regarde-dev/core\" build",
    "build:packages": "pnpm --filter \"./packages/*\" --filter \"!@regarde-dev/core\" --filter \"@regarde-dev/jazz-schemas\" build",
    "build:apps": "pnpm --filter \"./apps/regarde.bio/*\" --filter \"!@regarde-dev/jazz-schemas\" build",
    "build": "pnpm build:core && pnpm build:packages && pnpm build:apps",
    "test": "pnpm -r test",
    "test:run": "pnpm --filter \"*.test.ts\" test:run",
    "cli": "node packages/cli/dist/index.mjs",
    "format-and-lint": "oxfmt . --check && oxlint .",
    "format-and-lint:fix": "oxfmt . --write && oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint:ci": "oxlint . --deny-warnings",
    "lint:admin": "oxlint packages/admin",
    "lint:sdk": "oxlint packages/sdk",
    "lint:dashboard": "oxlint apps/dashboard.regarde.dev"
  },
  "dependencies": {
    "@scure/bip39": "catalog:",
    "jazz-tools": "catalog:",
    "preact": "catalog:"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/ui": "catalog:",
    "cojson-core-rn": "catalog:",
    "esbuild": "^0.27.2",
    "happy-dom": "^20.5.0",
    "jsdom": "^27.4.0",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.43.0",
    "rolldown": "1.0.0-beta.57",
    "vitest": "catalog:"
  }
}
